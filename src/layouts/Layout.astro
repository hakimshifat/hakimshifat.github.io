---
import Terminal from '../components/Terminal';

interface Props {
	title: string;
	description?: string;
}

const { title, description = "Just Something" } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
	</head>
	<body class="bg-[var(--bg)] text-[var(--ink)] font-sans selection:bg-[var(--accent)] selection:text-black transition-colors duration-300">
		<div class="fixed inset-0 pointer-events-none z-50 border-[1px] border-[var(--line)] m-4"></div>

		<header class="fixed top-0 left-0 right-0 z-40 bg-[var(--bg)]/95 backdrop-blur-md border-b border-[var(--line)]">
			<nav class="max-w-7xl mx-auto px-4 sm:px-6 h-16 flex items-center justify-between">
				<a href="/" class="font-mono text-[14px] tracking-tight font-medium text-[var(--ink)] hover:text-[var(--accent)] transition-colors">PORTFOLIO_OS.v1</a>
				<div class="flex items-center gap-4">
					<!-- Desktop Navigation -->
					<div class="hidden md:flex gap-8 text-[14px] uppercase tracking-wide font-medium text-[var(--ink-secondary)]">
						<a href="/blog" class="text-[var(--ink-secondary)] hover:text-[var(--ink)] hover:text-[var(--accent)] transition-colors">Archive</a>
						<a href="/projects" class="text-[var(--ink-secondary)] hover:text-[var(--ink)] hover:text-[var(--accent)] transition-colors">Projects</a>
						<a href="/education" class="text-[var(--ink-secondary)] hover:text-[var(--ink)] hover:text-[var(--accent)] transition-colors">Education</a>
						<a href="/media" class="text-[var(--ink-secondary)] hover:text-[var(--ink)] hover:text-[var(--accent)] transition-colors">Media</a>
						<a href="/about" class="text-[var(--ink-secondary)] hover:text-[var(--ink)] hover:text-[var(--accent)] transition-colors">About</a>
						<a href="/contact" class="text-[var(--ink-secondary)] hover:text-[var(--ink)] hover:text-[var(--accent)] transition-colors">Contact</a>
					</div>
					<button id="theme-toggle" class="p-2 border border-[var(--line)] hover:border-[var(--accent)] transition-all text-[var(--ink)]" title="Toggle Theme">
						<svg id="theme-icon" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707m12.728 0l-.707-.707M6.343 6.343l-.707-.707M12 5a7 7 0 100 14 7 7 0 000-14z"></path>
						</svg>
					</button>
					<!-- Mobile Menu Button -->
					<button id="mobile-menu-toggle" class="md:hidden p-2 border border-[var(--line)] hover:border-[var(--accent)] transition-all text-[var(--ink)]" title="Toggle Menu" aria-label="Toggle mobile menu">
						<svg id="mobile-menu-icon" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
						</svg>
					</button>
				</div>
			</nav>
		</header>

		<!-- Mobile Navigation Drawer -->
		<div id="mobile-nav" class="fixed inset-0 z-30 md:hidden hidden" aria-hidden="true">
			<div class="absolute inset-0 bg-[var(--bg)]/95 backdrop-blur-md transition-opacity" id="mobile-nav-overlay"></div>
			<div class="absolute top-0 right-0 h-full w-64 bg-[var(--bg)] border-l border-[var(--line)] shadow-lg transform transition-transform duration-300 ease-out" id="mobile-nav-drawer">
				<div class="flex flex-col h-full pt-20 px-6">
					<nav class="flex flex-col gap-4 text-[14px] uppercase tracking-wide font-medium">
						<a href="/blog" class="mobile-nav-link text-[var(--ink-secondary)] hover:text-[var(--ink)] hover:text-[var(--accent)] transition-colors py-2">Archive</a>
						<a href="/projects" class="mobile-nav-link text-[var(--ink-secondary)] hover:text-[var(--ink)] hover:text-[var(--accent)] transition-colors py-2">Projects</a>
						<a href="/education" class="mobile-nav-link text-[var(--ink-secondary)] hover:text-[var(--ink)] hover:text-[var(--accent)] transition-colors py-2">Education</a>
						<a href="/media" class="mobile-nav-link text-[var(--ink-secondary)] hover:text-[var(--ink)] hover:text-[var(--accent)] transition-colors py-2">Media</a>
						<a href="/about" class="mobile-nav-link text-[var(--ink-secondary)] hover:text-[var(--ink)] hover:text-[var(--accent)] transition-colors py-2">About</a>
						<a href="/contact" class="mobile-nav-link text-[var(--ink-secondary)] hover:text-[var(--ink)] hover:text-[var(--accent)] transition-colors py-2">Contact</a>
					</nav>
				</div>
			</div>
		</div>

		<main class="pt-24 pb-20 px-4 sm:px-6 max-w-7xl mx-auto">
			<slot />
		</main>

		<Terminal client:load />

		<footer class="border-t border-[var(--line)] py-12 px-4 sm:px-6 max-w-7xl mx-auto">
			<div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12">
				<div>
					<p class="font-mono text-[13px] uppercase tracking-wider text-[var(--ink-muted)] font-medium mb-4">System Status</p>
					<div class="flex items-center gap-2">
						<div class="w-1.5 h-1.5 rounded-full bg-[var(--accent)] animate-pulse"></div>
						<span class="text-[14px] font-mono text-[var(--ink-secondary)]">OPERATIONAL // 2026.03.20</span>
					</div>
				</div>
				<div>
					<p class="font-mono text-[13px] uppercase tracking-wider text-[var(--ink-muted)] font-medium mb-4">Navigation</p>
					<div class="flex flex-col gap-2 text-[14px] font-mono">
						<a href="/" class="text-[var(--ink-secondary)] hover:text-[var(--accent)] transition-colors">Home</a>
						<a href="/blog" class="text-[var(--ink-secondary)] hover:text-[var(--accent)] transition-colors">Archive</a>
						<a href="/projects" class="text-[var(--ink-secondary)] hover:text-[var(--accent)] transition-colors">Projects</a>
					</div>
				</div>
				<div class="text-right md:text-left">
					<p class="font-mono text-[13px] uppercase tracking-wider text-[var(--ink-muted)] font-medium mb-4">Connect</p>
					<div class="flex gap-4 text-[14px] font-mono justify-end md:justify-start">
						<a href="https://github.com/hakimshifat" target="_blank" rel="noopener noreferrer" class="text-[var(--ink-secondary)] hover:text-[var(--accent)] transition-colors">GitHub</a>
						<a href="https://linkedin.com/in/hakimshifat" target="_blank" rel="noopener noreferrer" class="text-[var(--ink-secondary)] hover:text-[var(--accent)] transition-colors">LinkedIn</a>
					</div>
				</div>
			</div>
			<div class="mt-8 md:mt-12 pt-8 border-t border-[var(--line)] flex flex-col md:flex-row justify-between items-center gap-4 text-[13px] font-mono text-[var(--ink-muted)]">
				<p>© 2026 PORTFOLIO_OS</p>
				<p>DESIGNED FOR THE VOID</p>
			</div>
		</footer>

		<script is:inline>
			const theme = (() => {
				if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
					return localStorage.getItem('theme');
				}
				return 'terminal';
			})();
			
			if (theme === 'minimal') {
				document.documentElement.setAttribute('data-theme', 'minimal');
			} else {
				document.documentElement.setAttribute('data-theme', 'terminal');
			}

			window.localStorage.setItem('theme', theme);

			const updateIcon = (theme) => {
				const icon = document.getElementById('theme-icon');
				if (theme === 'minimal') {
					icon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path>';
				} else {
					icon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707m12.728 0l-.707-.707M6.343 6.343l-.707-.707M12 5a7 7 0 100 14 7 7 0 000-14z"></path>';
				}
			};

			const handleToggleClick = () => {
				const element = document.documentElement;
				const isMinimal = element.getAttribute('data-theme') === 'minimal';
				const newTheme = isMinimal ? 'terminal' : 'minimal';
				element.setAttribute('data-theme', newTheme);
				localStorage.setItem('theme', newTheme);
				updateIcon(newTheme);
			};

			document.getElementById('theme-toggle').addEventListener('click', handleToggleClick);
			updateIcon(theme);

			// Mobile menu toggle
			const mobileMenuToggle = document.getElementById('mobile-menu-toggle');
			const mobileNav = document.getElementById('mobile-nav');
			const mobileNavOverlay = document.getElementById('mobile-nav-overlay');
			const mobileMenuIcon = document.getElementById('mobile-menu-icon');
			const mobileNavDrawer = document.getElementById('mobile-nav-drawer');
			const mobileNavLinks = document.querySelectorAll('.mobile-nav-link');

			const closeMobileNav = () => {
				mobileNavDrawer.classList.add('translate-x-full');
				setTimeout(() => {
					mobileNav.classList.add('hidden');
					mobileNav.setAttribute('aria-hidden', 'true');
				}, 300);
				mobileMenuIcon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>';
			};

			mobileMenuToggle.addEventListener('click', () => {
				const isHidden = mobileNav.classList.contains('hidden');
				if (isHidden) {
					mobileNav.classList.remove('hidden');
					mobileNav.setAttribute('aria-hidden', 'false');
					// Trigger slide-in animation
					setTimeout(() => {
						mobileNavDrawer.classList.remove('translate-x-full');
					}, 10);
					mobileMenuIcon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>';
				} else {
					closeMobileNav();
				}
			});

			mobileNavOverlay.addEventListener('click', closeMobileNav);

			mobileNavLinks.forEach(link => {
				link.addEventListener('click', closeMobileNav);
			});
		</script>

		<style is:global>
			@tailwind base;
			@tailwind components;
			@tailwind utilities;

			:root {
				/* Terminal (Dark) Theme - High Contrast */
				--bg: #0a0a0a;
				--bg-secondary: #121212;
				--ink: #f0f0f0;
				--ink-secondary: #a0a0a0;
				--ink-muted: #707070;
				--accent: #00ff00;
				--line: rgba(255, 255, 255, 0.12);
				--grid: rgba(255, 255, 255, 0.04);
			}

			[data-theme="minimal"] {
				/* Minimal (Light) Theme - High Contrast, inspired by tonybtw.com */
				--bg: #ffffff;
				--bg-secondary: #f8f9fa;
				--ink: #1a1a1a;
				--ink-secondary: #4a4a4a;
				--ink-muted: #6b7280;
				--accent: #4a75e8;
				--line: rgba(0, 0, 0, 0.12);
				--grid: rgba(0, 0, 0, 0.04);
			}

			html {
				scroll-behavior: smooth;
				background-color: var(--bg);
				font-size: 16px;
			}

			body {
				-webkit-font-smoothing: antialiased;
				-moz-osx-font-smoothing: grayscale;
				text-rendering: optimizeLegibility;
			}

			/* Typography Scale - Based on 16px root */
			/* Meta information: 13px (0.8125rem) - minimum readable size */
			/* Body text: 16px (1rem) - comfortable reading */
			/* Headings: Clear hierarchy with proper spacing */

			.text-meta {
				font-size: 0.8125rem;
				line-height: 1.5;
				letter-spacing: 0.05em;
			}

			.text-body {
				font-size: 1rem;
				line-height: 1.625;
			}

			.text-body-lg {
				font-size: 1.125rem;
				line-height: 1.6;
			}

			/* Custom scrollbar */
			::-webkit-scrollbar {
				width: 4px;
			}
			::-webkit-scrollbar-track {
				background: var(--bg);
			}
			::-webkit-scrollbar-thumb {
				background: var(--line);
			}
			::-webkit-scrollbar-thumb:hover {
				background: var(--accent);
			}

			/* Mobile Navigation Animations */
			#mobile-nav-drawer {
				transform: translateX(100%);
			}
			#mobile-nav:not(.hidden) #mobile-nav-drawer {
				transform: translateX(0);
			}

			/* Mobile-specific responsive adjustments */
			@media (max-width: 768px) {
				html {
					font-size: 15px;
				}
				.prose h1 {
					font-size: 2rem;
				}
				.prose h2 {
					font-size: 1.5rem;
				}
				.prose h3 {
					font-size: 1.25rem;
				}
			}

			.grid-lines {
				background-image: linear-gradient(to right, var(--grid) 1px, transparent 1px),
								  linear-gradient(to bottom, var(--grid) 1px, transparent 1px);
				background-size: 40px 40px;
			}

			/* Global Prose Styles - Optimized Typography */
			.prose {
				color: var(--ink);
				font-size: 1rem;
				line-height: 1.75;
			}
			.prose h1 {
				color: var(--ink) !important;
				font-family: "Playfair Display", serif;
				font-style: italic;
				font-weight: 700;
				letter-spacing: -0.02em;
				font-size: 2.5rem;
				line-height: 1.2;
				margin-top: 2.5rem;
				margin-bottom: 1.25rem;
			}
			.prose h2 {
				color: var(--ink) !important;
				font-family: "Playfair Display", serif;
				font-style: italic;
				font-weight: 600;
				letter-spacing: -0.02em;
				font-size: 2rem;
				line-height: 1.3;
				margin-top: 2.25rem;
				margin-bottom: 1rem;
			}
			.prose h3 {
				color: var(--ink) !important;
				font-family: "Playfair Display", serif;
				font-style: italic;
				font-weight: 600;
				letter-spacing: -0.01em;
				font-size: 1.5rem;
				line-height: 1.4;
				margin-top: 2rem;
				margin-bottom: 0.875rem;
			}
			.prose h4 {
				color: var(--ink) !important;
				font-family: "Playfair Display", serif;
				font-style: italic;
				font-weight: 600;
				font-size: 1.25rem;
				line-height: 1.4;
				margin-top: 1.75rem;
				margin-bottom: 0.75rem;
			}
			.prose a {
				color: var(--accent) !important;
				text-decoration-color: var(--line) !important;
				text-underline-offset: 2px;
			}
			.prose a:hover {
				text-decoration-color: var(--accent) !important;
			}
			.prose code {
				color: var(--accent) !important;
				background: var(--bg-secondary) !important;
				font-family: "JetBrains Mono", monospace;
				padding: 0.125rem 0.375rem;
				border-radius: 0.25rem;
				font-size: 0.875em;
			}
			.prose pre code {
				background: transparent !important;
				padding: 0;
			}
			.prose pre {
				background: var(--bg-secondary) !important;
				border: 1px solid var(--line);
				padding: 1.5rem;
				border-radius: 0.5rem;
				margin: 1.5rem 0;
				overflow-x: auto;
			}
			.prose blockquote {
				border-left-color: var(--accent) !important;
				color: var(--ink-secondary) !important;
				font-style: italic;
				padding-left: 1.25rem;
				margin: 1.5rem 0;
				border-left-width: 3px;
			}
			.prose strong {
				color: var(--ink) !important;
				font-weight: 600;
			}
			.prose p {
				line-height: 1.75;
				margin-bottom: 1.5rem;
			}
			.prose ul, .prose ol {
				line-height: 1.7;
				margin-bottom: 1.5rem;
				padding-left: 1.5rem;
			}
			.prose li {
				margin-bottom: 0.5rem;
			}
			.prose img {
				margin: 2rem 0;
				border-radius: 0.5rem;
			}
		</style>
	</body>
</html>
