---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
	const mediaEntries = await getCollection('media');
	return mediaEntries.map(entry => ({
		params: { slug: entry.slug }, props: { entry },
	}));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
---

<Layout title={`${entry.data.title} // MEDIA_RECORD`}>
	<div class="grid-lines fixed inset-0 pointer-events-none z-0"></div>

	<div class="relative z-10">
		<header class="py-20 border-b border-[var(--line)]">
			<div class="flex flex-col md:flex-row gap-12 items-end justify-between">
				<div class="flex flex-col gap-4">
					<div class="flex items-center gap-4">
						<span class="font-mono text-[11px] uppercase tracking-widest text-[var(--accent)]">{entry.data.category}</span>
						<span class="w-8 h-[1px] bg-[var(--line)]"></span>
						<span class="font-mono text-[11px] uppercase tracking-widest text-[var(--ink-muted)]">{entry.data.year}</span>
					</div>
					<h1 class="text-6xl md:text-8xl font-display italic tracking-tighter text-[var(--ink)]">{entry.data.title}</h1>
				</div>
				{entry.data.rating && (
					<div class="flex flex-col items-end">
						<span class="font-mono text-[10px] uppercase tracking-widest text-[var(--ink-muted)] mb-2">SYSTEM_RATING</span>
						<span class="text-4xl font-display italic text-[var(--accent)]">{entry.data.rating}/10</span>
					</div>
				)}
			</div>
		</header>

		<section class="py-20 flex flex-col md:flex-row gap-20">
			<div class="md:w-1/3">
				<div class="aspect-[2/3] overflow-hidden border border-[var(--line)]">
					<img
						src={entry.data.image}
						alt={entry.data.title}
						class="w-full h-full object-cover"
						referrerpolicy="no-referrer"
					/>
				</div>
				<div class="mt-8 flex flex-col gap-4 font-mono text-[11px] uppercase tracking-widest text-[var(--ink-muted)]">
					<div class="flex justify-between border-b border-[var(--line)] pb-2">
						<span>RECORD_ID</span>
						<span>0x{entry.slug.toUpperCase()}</span>
					</div>
					{entry.data.status && (
						<div class="flex justify-between border-b border-[var(--line)] pb-2">
							<span>STATUS</span>
							<span class="text-[var(--ink-secondary)]">{entry.data.status}</span>
						</div>
					)}
					<div class="flex justify-between border-b border-[var(--line)] pb-2">
						<span>LOGGED_ON</span>
						<span class="text-[var(--ink-secondary)]">{entry.data.pubDate.toLocaleDateString()}</span>
					</div>
				</div>
			</div>

			<div class="md:w-2/3">
				<div class="prose prose-lg max-w-none font-light leading-relaxed">
					<Content />
				</div>

				<div class="mt-20 pt-12 border-t border-[var(--line)]">
					<a href="/media" class="font-mono text-[11px] uppercase tracking-widest text-[var(--ink-secondary)] hover:text-[var(--accent)] transition-colors">
						← RETURN_TO_ARCHIVE
					</a>
				</div>
			</div>
		</section>
	</div>
</Layout>

<style is:global>
	.prose p {
		margin-bottom: 2rem;
	}
	.prose h2 {
		font-family: 'Georgia', serif;
		font-style: italic;
		font-size: 2rem;
		margin-top: 3rem;
		margin-bottom: 1.5rem;
		color: var(--ink);
	}
</style>
