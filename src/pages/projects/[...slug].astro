---
import { getCollection, type CollectionEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
	const projects = await getCollection('projects');
	return projects.map((project) => ({
		params: { slug: project.slug },
		props: project,
	}));
}

const project = Astro.props as CollectionEntry<'projects'>;
const { Content } = await project.render();
---

<Layout title={`${project.data.title} // Portfolio_OS`} description={project.data.description}>
	<div class="grid-lines fixed inset-0 pointer-events-none z-0"></div>

	<div class="relative z-10">
		<article class="py-20 max-w-3xl mx-auto">
			<header class="mb-20">
				<div class="flex items-center gap-4 mb-8">
					<div class="w-1.5 h-1.5 rounded-full bg-[var(--accent)]"></div>
					<span class="font-mono text-[11px] uppercase tracking-widest text-[var(--ink-secondary)]">
						{project.data.pubDate.toLocaleDateString('en-US', {
							year: 'numeric',
							month: 'long',
							day: 'numeric',
						})}
					</span>
				</div>
				<h1 class="text-6xl md:text-8xl font-display font-light leading-[0.9] tracking-tighter mb-8 italic text-[var(--ink)]">
					{project.data.title}
				</h1>
				<p class="text-xl font-light text-[var(--ink-secondary)] leading-relaxed italic">
					{project.data.description}
				</p>
			</header>

			{project.data.heroImage && (
				<div class="mb-20 aspect-video overflow-hidden border border-[var(--line)]">
					<img
						src={project.data.heroImage}
						alt={project.data.title}
						class="w-full h-full object-cover"
						referrerpolicy="no-referrer"
					/>
				</div>
			)}

			<div class="prose max-w-none font-sans leading-relaxed text-lg">
				<Content />
			</div>

			<footer class="mt-20 pt-12 border-t border-[var(--line)]">
				<div class="flex flex-wrap gap-4 mb-12">
					{project.data.tags.map((tag) => (
						<span class="text-[10px] font-mono uppercase tracking-widest text-[var(--ink-muted)] border border-[var(--line)] px-2 py-1">
							{tag}
						</span>
					))}
				</div>

				{project.data.link && (
					<div class="mb-12">
						<a href={project.data.link} target="_blank" rel="noopener noreferrer" class="font-mono text-[11px] uppercase tracking-widest text-[var(--accent)] hover:underline">
							External_Link: {project.data.link}
						</a>
					</div>
				)}

				<a href="/projects" class="font-mono text-[11px] uppercase tracking-widest text-[var(--ink-secondary)] hover:text-[var(--accent)] transition-colors">
					← Return to Projects
				</a>
			</footer>
		</article>
	</div>
</Layout>

<style is:global>
	/* Custom styles for the project content */
	.prose h1, .prose h2, .prose h3, .prose h4 {
		font-family: "Playfair Display", serif;
		font-style: italic;
		font-weight: 600;
		letter-spacing: -0.02em;
		margin-top: 2.5em;
		margin-bottom: 1em;
		color: var(--ink);
	}

	.prose p {
		margin-bottom: 1.5em;
	}

	.prose code {
		font-family: "JetBrains Mono", monospace;
		font-size: 0.9em;
		background: var(--bg-secondary);
		padding: 0.2em 0.4em;
		border-radius: 4px;
		color: var(--accent);
	}

	.prose pre {
		background: var(--bg-secondary) !important;
		border: 1px solid var(--line);
		padding: 2em;
		border-radius: 0;
		margin: 2em 0;
	}

	.prose blockquote {
		border-left: 2px solid var(--accent);
		padding-left: 2em;
		font-style: italic;
		color: var(--ink-secondary);
		margin: 2em 0;
	}

	.prose ul {
		list-style-type: square;
		padding-left: 1.5em;
		margin-bottom: 1.5em;
	}

	.prose li {
		margin-bottom: 0.5em;
	}
</style>
