---
import { getCollection, type CollectionEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import BlogSearch from '../../components/BlogSearch';

const posts: CollectionEntry<'blog'>[] = (await getCollection('blog')).sort(
	(a: CollectionEntry<'blog'>, b: CollectionEntry<'blog'>) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

// Map posts to a simpler structure for the React component
const searchPosts = posts.map(post => ({
	slug: post.slug,
	data: {
		title: post.data.title,
		description: post.data.description,
		pubDate: post.data.pubDate,
		tags: post.data.tags,
		heroImage: post.data.heroImage,
	}
}));
---

<Layout title="ARCHIVE // Portfolio_OS">
	<div class="grid-lines fixed inset-0 pointer-events-none z-0"></div>

	<div class="relative z-10">
		<header class="py-20 border-b border-[var(--line)] text-center">
			<h1 class="text-6xl font-display italic tracking-tighter text-[var(--ink)] mb-4">Archive</h1>
			<p class="font-mono text-[11px] uppercase tracking-widest text-[var(--ink-secondary)]">Total Records: {posts.length}</p>
		</header>

		<section class="py-20">
			<BlogSearch client:load posts={searchPosts} />
		</section>
	</div>
</Layout>
